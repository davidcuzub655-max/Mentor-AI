<!DOCTYPE html>
<html lang="ro">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>MENTOR AI - Profesorul personal din buzunarul tau</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
:root{--primary:#1a1a4e;--primary-light:#2d2d7a;--secondary:#7c3aed;--accent:#f59e0b;--accent-light:#fbbf24;--bg:#0f0f23;--bg-card:#1a1a3e;--bg-card-hover:#222250;--bg-input:#151530;--text:#f1f5f9;--text-secondary:#94a3b8;--text-muted:#64748b;--success:#10b981;--warning:#f59e0b;--danger:#ef4444;--info:#3b82f6;--gradient-primary:linear-gradient(135deg,#1a1a4e 0%,#7c3aed 100%);--gradient-accent:linear-gradient(135deg,#f59e0b 0%,#fbbf24 100%);--gradient-card:linear-gradient(145deg,#1a1a3e 0%,#252560 100%);--shadow:0 8px 32px rgba(0,0,0,0.4);--shadow-glow:0 0 40px rgba(124,58,237,0.3);--radius:20px;--radius-sm:12px;--radius-lg:24px;--transition:all 0.3s cubic-bezier(0.4,0,0.2,1)}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
body{font-family:'Inter',-apple-system,sans-serif;background:var(--bg);color:var(--text);overflow-x:hidden;min-height:100vh;-webkit-font-smoothing:antialiased}
.app-container{max-width:480px;margin:0 auto;min-height:100vh;position:relative;background:var(--bg);overflow:hidden}
.screen{display:none;animation:fadeIn 0.4s ease;padding-bottom:100px;min-height:100vh}
.screen.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes slideUp{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:translateY(0)}}
@keyframes rotate{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}
@keyframes flicker{0%{transform:scale(1);opacity:1}100%{transform:scale(1.1);opacity:0.8}}
@keyframes splashPulse{0%,100%{transform:scale(1);box-shadow:0 0 40px rgba(124,58,237,0.3)}50%{transform:scale(1.05);box-shadow:0 0 60px rgba(124,58,237,0.5)}}
.splash-screen{position:fixed;inset:0;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:10000;transition:opacity 0.8s ease,transform 0.8s ease}
.splash-screen.hidden{opacity:0;transform:scale(1.1);pointer-events:none}
.splash-logo{width:120px;height:120px;background:var(--gradient-primary);border-radius:28px;display:flex;align-items:center;justify-content:center;font-size:56px;font-weight:900;color:white;box-shadow:var(--shadow-glow);animation:splashPulse 2s ease-in-out infinite;margin-bottom:24px}
.splash-title{font-size:32px;font-weight:800;background:var(--gradient-primary);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:8px}
.splash-subtitle{font-size:14px;color:var(--text-secondary);text-align:center;max-width:280px;line-height:1.6}
.splash-slogan{margin-top:32px;font-size:13px;color:var(--text-muted);text-align:center;font-weight:500}
.auth-screen{padding:40px 24px;display:flex;flex-direction:column;align-items:center;min-height:100vh}
.auth-logo{width:80px;height:80px;background:var(--gradient-primary);border-radius:22px;display:flex;align-items:center;justify-content:center;font-size:36px;font-weight:900;color:white;margin-bottom:24px;box-shadow:var(--shadow-glow)}
.auth-title{font-size:26px;font-weight:800;margin-bottom:8px;text-align:center}
.auth-subtitle{font-size:14px;color:var(--text-secondary);margin-bottom:40px;text-align:center}
.btn{width:100%;padding:16px 24px;border:none;border-radius:var(--radius-sm);font-size:15px;font-weight:600;cursor:pointer;transition:var(--transition);display:flex;align-items:center;justify-content:center;gap:12px;font-family:inherit}
.btn:active{transform:scale(0.97)}
.btn-primary{background:var(--gradient-primary);color:white;box-shadow:0 4px 20px rgba(124,58,237,0.4)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(124,58,237,0.5)}
.btn-secondary{background:var(--bg-card);color:var(--text);border:1px solid rgba(255,255,255,0.1)}
.btn-secondary:hover{background:var(--bg-card-hover);border-color:rgba(255,255,255,0.2)}
.btn-accent{background:var(--gradient-accent);color:var(--primary);font-weight:700}
.btn-outline{background:transparent;color:var(--text-secondary);border:1.5px solid rgba(255,255,255,0.15)}
.btn-outline:hover{border-color:var(--secondary);color:var(--text)}
.btn-social{background:var(--bg-card);color:var(--text);border:1px solid rgba(255,255,255,0.08)}
.btn-social:hover{background:var(--bg-card-hover)}
.auth-buttons{width:100%;display:flex;flex-direction:column;gap:12px}
.auth-divider{width:100%;display:flex;align-items:center;gap:16px;margin:24px 0;color:var(--text-muted);font-size:13px}
.auth-divider::before,.auth-divider::after{content:'';flex:1;height:1px;background:rgba(255,255,255,0.1)}
.auth-footer{margin-top:auto;padding-top:40px;text-align:center;font-size:13px;color:var(--text-muted)}
.auth-footer a{color:var(--secondary);text-decoration:none;font-weight:600}
.form-group{width:100%;margin-bottom:16px}
.form-label{display:block;font-size:13px;font-weight:600;color:var(--text-secondary);margin-bottom:8px}
.form-input{width:100%;padding:14px 18px;background:var(--bg-input);border:1.5px solid rgba(255,255,255,0.08);border-radius:var(--radius-sm);color:var(--text);font-size:15px;font-family:inherit;transition:var(--transition)}
.form-input:focus{outline:none;border-color:var(--secondary);box-shadow:0 0 0 3px rgba(124,58,237,0.15)}
.form-input::placeholder{color:var(--text-muted)}
.onboarding-screen{padding:40px 24px;min-height:100vh;display:flex;flex-direction:column}
.onboarding-header{margin-bottom:32px}
.onboarding-step{font-size:12px;color:var(--secondary);font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}
.onboarding-title{font-size:24px;font-weight:800;margin-bottom:8px}
.onboarding-desc{font-size:14px;color:var(--text-secondary);line-height:1.6}
.onboarding-options{display:flex;flex-direction:column;gap:10px;margin-bottom:24px}
.option-card{padding:16px 20px;background:var(--bg-card);border:2px solid transparent;border-radius:var(--radius-sm);cursor:pointer;transition:var(--transition);display:flex;align-items:center;gap:14px}
.option-card:hover{background:var(--bg-card-hover);border-color:rgba(124,58,237,0.3)}
.option-card.selected{border-color:var(--secondary);background:rgba(124,58,237,0.1)}
.option-card i{font-size:20px;color:var(--secondary);width:36px;height:36px;display:flex;align-items:center;justify-content:center;background:rgba(124,58,237,0.15);border-radius:10px}
.option-card span{font-size:15px;font-weight:600}
.onboarding-progress{margin-top:auto;padding-top:24px}
.progress-bar{width:100%;height:6px;background:rgba(255,255,255,0.08);border-radius:3px;overflow:hidden}
.progress-fill{height:100%;background:var(--gradient-primary);border-radius:3px;transition:width 0.5s ease}
.home-header{padding:20px 20px 0;display:flex;justify-content:space-between;align-items:center}
.home-greeting{font-size:14px;color:var(--text-secondary)}
.home-greeting strong{color:var(--text);font-size:20px;display:block;margin-top:4px}
.home-countdown{background:var(--gradient-primary);padding:8px 16px;border-radius:var(--radius-sm);font-size:12px;font-weight:600;text-align:center}
.home-countdown span{display:block;font-size:18px;font-weight:800}
.score-card{margin:20px;padding:24px;background:var(--gradient-card);border-radius:var(--radius-lg);border:1px solid rgba(255,255,255,0.05);position:relative;overflow:hidden}
.score-card::before{content:'';position:absolute;top:-50%;right:-20%;width:200px;height:200px;background:radial-gradient(circle,rgba(124,58,237,0.2) 0%,transparent 70%);border-radius:50%}
.score-label{font-size:12px;color:var(--text-secondary);text-transform:uppercase;letter-spacing:1px;font-weight:700;margin-bottom:16px}
.score-circle-container{display:flex;align-items:center;gap:24px}
.score-circle{position:relative;width:120px;height:120px;flex-shrink:0}
.score-circle svg{transform:rotate(-90deg)}
.score-circle-bg{fill:none;stroke:rgba(255,255,255,0.08);stroke-width:8}
.score-circle-fill{fill:none;stroke:url(#scoreGradient);stroke-width:8;stroke-linecap:round;stroke-dasharray:339.292;stroke-dashoffset:339.292;transition:stroke-dashoffset 1.5s ease}
.score-value{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:32px;font-weight:900}
.score-details{flex:1}
.score-detail-item{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.05)}
.score-detail-item:last-child{border-bottom:none}
.score-detail-label{font-size:13px;color:var(--text-secondary)}
.score-detail-value{font-size:14px;font-weight:700}
.score-detail-value.positive{color:var(--success)}
.section{margin:0 20px 20px}
.section-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.section-title{font-size:16px;font-weight:700}
.section-action{font-size:13px;color:var(--secondary);font-weight:600;cursor:pointer}
.progress-bar-linear{width:100%;height:10px;background:rgba(255,255,255,0.08);border-radius:5px;overflow:hidden;margin-bottom:8px}
.progress-fill-linear{height:100%;background:var(--gradient-primary);border-radius:5px;transition:width 1s ease;position:relative}
.progress-fill-linear::after{content:'';position:absolute;right:0;top:0;bottom:0;width:20px;background:linear-gradient(90deg,transparent,rgba(255,255,255,0.3));border-radius:5px}
.progress-text{font-size:13px;color:var(--text-secondary);text-align:right}
.cards-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.info-card{background:var(--bg-card);border-radius:var(--radius);padding:16px;border:1px solid rgba(255,255,255,0.05);transition:var(--transition)}
.info-card:hover{background:var(--bg-card-hover);transform:translateY(-2px)}
.info-card-icon{width:40px;height:40px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:18px;margin-bottom:12px}
.info-card-icon.blue{background:rgba(59,130,246,0.15);color:#60a5fa}
.info-card-icon.green{background:rgba(16,185,129,0.15);color:#34d399}
.info-card-icon.purple{background:rgba(124,58,237,0.15);color:#a78bfa}
.info-card-icon.orange{background:rgba(245,158,11,0.15);color:#fbbf24}
.info-card-icon.red{background:rgba(239,68,68,0.15);color:#f87171}
.info-card-title{font-size:13px;font-weight:600;margin-bottom:4px}
.info-card-value{font-size:20px;font-weight:800}
.info-card-sub{font-size:11px;color:var(--text-muted);margin-top:4px}
.schedule-card{background:var(--bg-card);border-radius:var(--radius);padding:16px;border:1px solid rgba(255,255,255,0.05)}
.schedule-item{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.05)}
.schedule-item:last-child{border-bottom:none}
.schedule-time{font-size:13px;font-weight:700;color:var(--secondary);min-width:50px}
.schedule-subject{flex:1;font-size:14px;font-weight:600}
.schedule-status{width:8px;height:8px;border-radius:50%}
.schedule-status.done{background:var(--success)}
.schedule-status.now{background:var(--accent);animation:pulse 2s infinite}
.schedule-status.next{background:var(--text-muted)}
.alert-card{background:linear-gradient(135deg,rgba(245,158,11,0.15) 0%,rgba(245,158,11,0.05) 100%);border:1px solid rgba(245,158,11,0.2);border-radius:var(--radius);padding:16px;display:flex;align-items:flex-start;gap:12px}
.alert-card.danger{background:linear-gradient(135deg,rgba(239,68,68,0.15) 0%,rgba(239,68,68,0.05) 100%);border-color:rgba(239,68,68,0.2)}
.alert-icon{font-size:20px;color:var(--warning)}
.alert-card.danger .alert-icon{color:var(--danger)}
.alert-content{flex:1}
.alert-title{font-size:14px;font-weight:700;margin-bottom:4px}
.alert-text{font-size:13px;color:var(--text-secondary);line-height:1.5}
.ai-recommendation{background:var(--gradient-card);border-radius:var(--radius-lg);padding:20px;border:1px solid rgba(124,58,237,0.2);position:relative;overflow:hidden}
.ai-recommendation::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--gradient-primary)}
.ai-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(124,58,237,0.2);color:#a78bfa;padding:4px 12px;border-radius:20px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:12px}
.ai-recommendation-text{font-size:15px;line-height:1.6;margin-bottom:16px}
.ai-recommendation-items{display:flex;flex-direction:column;gap:8px}
.ai-rec-item{display:flex;align-items:center;gap:10px;padding:10px 14px;background:rgba(0,0,0,0.2);border-radius:var(--radius-sm)}
.ai-rec-item i{color:var(--secondary);font-size:14px}
.ai-rec-item span{font-size:14px;font-weight:600}
.ai-rec-item small{margin-left:auto;font-size:12px;color:var(--text-muted)}
.big-action{margin:20px;padding:20px;background:var(--gradient-primary);border-radius:var(--radius-lg);display:flex;align-items:center;justify-content:center;gap:12px;font-size:16px;font-weight:700;color:white;cursor:pointer;transition:var(--transition);border:none;width:calc(100% - 40px);font-family:inherit;box-shadow:0 8px 30px rgba(124,58,237,0.4)}
.big-action:hover{transform:translateY(-3px);box-shadow:0 12px 40px rgba(124,58,237,0.5)}
.big-action:active{transform:scale(0.98)}
.big-action i{font-size:20px}
.bottom-nav{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:rgba(15,15,35,0.95);backdrop-filter:blur(20px);border-top:1px solid rgba(255,255,255,0.05);display:flex;justify-content:space-around;padding:8px 0 24px;z-index:1000}
.nav-item{display:flex;flex-direction:column;align-items:center;gap:4px;padding:8px 16px;cursor:pointer;transition:var(--transition);border:none;background:none;color:var(--text-muted);font-family:inherit}
.nav-item.active{color:var(--secondary)}
.nav-item i{font-size:22px;transition:var(--transition)}
.nav-item.active i{transform:translateY(-2px)}
.nav-item span{font-size:10px;font-weight:600}
.professor-header{padding:20px;text-align:center;position:relative}
.professor-avatar{width:100px;height:100px;margin:0 auto 16px;position:relative}
.professor-avatar-img{width:100%;height:100%;border-radius:50%;background:var(--gradient-primary);display:flex;align-items:center;justify-content:center;font-size:48px;box-shadow:var(--shadow-glow);position:relative;z-index:2}
.professor-avatar-ring{position:absolute;inset:-6px;border-radius:50%;border:2px solid transparent;border-top-color:var(--secondary);border-right-color:var(--secondary);animation:rotate 3s linear infinite}
.professor-status{position:absolute;bottom:4px;right:4px;width:20px;height:20px;background:var(--success);border-radius:50%;border:3px solid var(--bg);z-index:3}
.professor-name{font-size:22px;font-weight:800;margin-bottom:4px}
.professor-role{font-size:13px;color:var(--text-secondary)}
.professor-question{font-size:18px;font-weight:700;text-align:center;padding:0 20px;margin-bottom:24px}
.input-methods{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding:0 20px;margin-bottom:20px}
.input-method{background:var(--bg-card);border:1px solid rgba(255,255,255,0.05);border-radius:var(--radius);padding:20px;text-align:center;cursor:pointer;transition:var(--transition)}
.input-method:hover{background:var(--bg-card-hover);border-color:var(--secondary);transform:translateY(-3px)}
.input-method i{font-size:28px;color:var(--secondary);margin-bottom:10px;display:block}
.input-method span{font-size:13px;font-weight:600;display:block}
.input-method small{font-size:11px;color:var(--text-muted)}
.chat-container{display:flex;flex-direction:column;height:calc(100vh - 80px);padding-bottom:80px}
.chat-messages{flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:16px}
.chat-message{max-width:85%;padding:14px 18px;border-radius:var(--radius);font-size:14px;line-height:1.6;animation:slideUp 0.3s ease}
.chat-message.ai{align-self:flex-start;background:var(--bg-card);border:1px solid rgba(255,255,255,0.05);border-bottom-left-radius:4px}
.chat-message.user{align-self:flex-end;background:var(--gradient-primary);border-bottom-right-radius:4px}
.chat-input-area{padding:12px 20px 20px;background:rgba(15,15,35,0.95);backdrop-filter:blur(20px);border-top:1px solid rgba(255,255,255,0.05);display:flex;gap:10px;align-items:center}
.chat-input{flex:1;padding:12px 18px;background:var(--bg-input);border:1px solid rgba(255,255,255,0.08);border-radius:24px;color:var(--text);font-size:14px;font-family:inherit;outline:none}
.chat-input:focus{border-color:var(--secondary)}
.chat-send{width:44px;height:44px;border-radius:50%;background:var(--gradient-primary);border:none;color:white;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:var(--transition)}
.chat-send:hover{transform:scale(1.1)}
.learn-options{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding:0 20px}
.learn-option{background:var(--bg-card);border:2px solid transparent;border-radius:var(--radius);padding:24px 16px;text-align:center;cursor:pointer;transition:var(--transition)}
.learn-option:hover{border-color:var(--secondary);background:var(--bg-card-hover);transform:translateY(-3px)}
.learn-option.selected{border-color:var(--secondary);background:rgba(124,58,237,0.1)}
.learn-option i{font-size:32px;margin-bottom:12px;display:block}
.learn-option span{font-size:14px;font-weight:700;display:block}
.timer-screen{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:calc(100vh - 100px);padding:20px}
.timer-circle-big{width:260px;height:260px;position:relative;margin-bottom:40px}
.timer-circle-big svg{transform:rotate(-90deg)}
.timer-circle-bg{fill:none;stroke:rgba(255,255,255,0.08);stroke-width:12}
.timer-circle-fill{fill:none;stroke:url(#timerGradient);stroke-width:12;stroke-linecap:round;stroke-dasharray:754;stroke-dashoffset:754;transition:stroke-dashoffset 1s linear}
.timer-display{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center}
.timer-time{font-size:56px;font-weight:900;font-variant-numeric:tabular-nums;letter-spacing:-2px}
.timer-label{font-size:14px;color:var(--text-secondary);margin-top:4px}
.timer-subject{font-size:18px;font-weight:700;margin-bottom:8px}
.timer-chapter{font-size:14px;color:var(--text-secondary);margin-bottom:32px}
.timer-controls{display:flex;gap:20px;margin-bottom:32px}
.timer-btn{width:64px;height:64px;border-radius:50%;border:none;display:flex;align-items:center;justify-content:center;font-size:24px;cursor:pointer;transition:var(--transition);color:white}
.timer-btn.play{background:var(--gradient-primary);box-shadow:0 8px 30px rgba(124,58,237,0.4)}
.timer-btn.pause{background:var(--warning);box-shadow:0 8px 30px rgba(245,158,11,0.4)}
.timer-btn.stop{background:var(--danger);box-shadow:0 8px 30px rgba(239,68,68,0.4)}
.timer-btn:hover{transform:scale(1.1)}
.timer-sounds{display:flex;gap:10px;flex-wrap:wrap;justify-content:center}
.sound-chip{padding:8px 16px;background:var(--bg-card);border:1px solid rgba(255,255,255,0.08);border-radius:20px;font-size:12px;font-weight:600;color:var(--text-secondary);cursor:pointer;transition:var(--transition);border:none;font-family:inherit}
.sound-chip:hover,.sound-chip.active{background:var(--secondary);color:white;border-color:var(--secondary)}
.profile-header{padding:20px;text-align:center;position:relative}
.profile-cover{position:absolute;top:0;left:0;right:0;height:120px;background:var(--gradient-primary);opacity:0.3;border-radius:0 0 var(--radius-lg) var(--radius-lg)}
.profile-avatar-container{position:relative;width:100px;height:100px;margin:40px auto 16px}
.profile-avatar{width:100%;height:100%;border-radius:50%;background:var(--gradient-primary);display:flex;align-items:center;justify-content:center;font-size:40px;border:4px solid var(--bg);box-shadow:var(--shadow);overflow:hidden}
.profile-avatar img{width:100%;height:100%;object-fit:cover}
.profile-level-badge{position:absolute;bottom:-4px;right:-4px;background:var(--gradient-accent);color:var(--primary);padding:4px 12px;border-radius:12px;font-size:12px;font-weight:800;border:3px solid var(--bg)}
.profile-name{font-size:22px;font-weight:800;margin-bottom:4px}
.profile-school{font-size:13px;color:var(--text-secondary);margin-bottom:16px}
.profile-stats-row{display:flex;justify-content:center;gap:24px;margin-bottom:20px}
.profile-stat{text-align:center}
.profile-stat-value{font-size:20px;font-weight:800;display:block}
.profile-stat-label{font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px}
.xp-bar-container{margin:0 20px 20px;padding:16px;background:var(--bg-card);border-radius:var(--radius)}
.xp-bar-header{display:flex;justify-content:space-between;margin-bottom:8px;font-size:13px}
.xp-bar-header span:first-child{font-weight:700}
.xp-bar-header span:last-child{color:var(--text-muted)}
