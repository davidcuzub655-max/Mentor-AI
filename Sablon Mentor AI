}

function closeModal(){
    document.getElementById('modal').classList.remove('active');
}

function startVoiceChat(){
    showToast('Se activeaza microfonul...','info');
    setTimeout(()=>{showScreen('chatScreen');showToast('Profesorul te asculta! Vorbeste acum.','success')},1500);
}

document.querySelectorAll('.sound-chip').forEach(chip=>{
    chip.addEventListener('click',function(){
        document.querySelectorAll('.sound-chip').forEach(c=>c.classList.remove('active'));
        this.classList.add('active');
    });
});
</script>
</body>
