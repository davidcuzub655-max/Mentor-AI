<script>
let currentScreen='authScreen';
let userData={name:'Andrei',level:24,xp:8450,coins:1240,streak:12,score:92,school:'Liceul Teoretic "Mihai Eminescu"',class:'a XII-a A'};
let timerInterval=null;
let timerSeconds=25*60;
let isTimerRunning=false;

window.addEventListener('load',()=>{
    setTimeout(()=>{document.getElementById('splashScreen').classList.add('hidden')},2500);
});

function showScreen(screenId){
    document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
    document.getElementById(screenId).classList.add('active');
    currentScreen=screenId;
    window.scrollTo(0,0);
    if(screenId==='homeScreen'){setTimeout(()=>animateScore(),500)}
    if(screenId==='calendarScreen'){generateCalendar()}
}

function navigateTo(screen){
    const map={'home':'homeScreen','professor':'professorScreen','learn':'learnTypeScreen','calendar':'calendarScreen','profile':'profileScreen'};
    document.querySelectorAll('.nav-item').forEach(item=>item.classList.remove('active'));
    event.currentTarget.classList.add('active');
    showScreen(map[screen]);
}

function startOnboarding(){
    const name=document.getElementById('regName').value||'Andrei';
    userData.name=name;
    showScreen('onboarding1');
}

function finishOnboarding(){
    showScreen('homeScreen');
    showToast('Bun venit, '+userData.name+'! Profilul tau este gata.','success');
    animateScore();
}

function selectOption(element){
    const parent=element.parentElement;
    parent.querySelectorAll('.option-card').forEach(c=>c.classList.remove('selected'));
    element.classList.add('selected');
}

function animateScore(){
    const circle=document.getElementById('scoreCircle');
    const value=document.getElementById('scoreValue');
    if(!circle||!value)return;
    const targetScore=92;
    const circumference=339.292;
    const offset=circumference-(targetScore/100)*circumference;
    circle.style.strokeDashoffset=offset;
    let current=0;
    const increment=targetScore/60;
    const interval=setInterval(()=>{
        current+=increment;
        if(current>=targetScore){current=targetScore;clearInterval(interval)}
        value.textContent=Math.floor(current);
    },25);
}

function sendMessage(){
    const input=document.getElementById('chatInput');
    const message=input.value.trim();
    if(!message)return;
    const messagesContainer=document.getElementById('chatMessages');
    const userMsg=document.createElement('div');
    userMsg.className='chat-message user';
    userMsg.textContent=message;
    messagesContainer.appendChild(userMsg);
    input.value='';
    messagesContainer.scrollTop=messagesContainer.scrollHeight;
    setTimeout(()=>{
        const aiMsg=document.createElement('div');
        aiMsg.className='chat-message ai';
        const responses=['Excelenta intrebare! Hai sa vedem impreuna cum putem aborda acest subiect.','Inteleg unde vrei sa ajungi. Iata o explicatie pas cu pas:','Foarte bine ca intrebi! Acest concept este fundamental.','Hai sa descompunem problema in pasi mici si usor de inteles.','Perfect! Voi crea un rezumat vizual pentru tine.'];
        aiMsg.innerHTML=responses[Math.floor(Math.random()*responses.length)];
        messagesContainer.appendChild(aiMsg);
        messagesContainer.scrollTop=messagesContainer.scrollHeight;
    },800+Math.random()*1000);
}

function startTimer(){
    timerSeconds=25*60;
    isTimerRunning=false;
    updateTimerDisplay();
}

function toggleTimer(){
    const btn=document.getElementById('timerPlayBtn');
    const icon=document.getElementById('timerPlayIcon');
    if(isTimerRunning){
        clearInterval(timerInterval);
        isTimerRunning=false;
        btn.className='timer-btn play';
        icon.className='fas fa-play';
    }else{
        isTimerRunning=true;
        btn.className='timer-btn pause';
        icon.className='fas fa-pause';
        timerInterval=setInterval(()=>{
            timerSeconds--;
            updateTimerDisplay();
            if(timerSeconds<=0){clearInterval(timerInterval);showScreen('reportScreen');isTimerRunning=false}
        },1000);
    }
}

function stopTimer(){
    clearInterval(timerInterval);
    isTimerRunning=false;
    showScreen('reportScreen');
}

function updateTimerDisplay(){
    const display=document.getElementById('timerDisplay');
    const circle=document.getElementById('timerCircle');
    if(!display||!circle)return;
    const mins=Math.floor(timerSeconds/60);
    const secs=timerSeconds%60;
    display.textContent=mins.toString().padStart(2,'0')+':'+secs.toString().padStart(2,'0');
    const circumference=754;
    const totalSeconds=25*60;
    const offset=circumference-((totalSeconds-timerSeconds)/totalSeconds)*circumference;
    circle.style.strokeDashoffset=offset;
}

function selectLearnType(element,type){
    document.querySelectorAll('.learn-option').forEach(o=>o.classList.remove('selected'));
    element.classList.add('selected');
}

function generateCalendar(){
    const container=document.getElementById('calendarDates');
    if(!container)return;
    container.innerHTML='';
    const daysInMonth=31;
    const startDay=3;
    const today=19;
    for(let i=0;i<startDay;i++){const empty=document.createElement('div');container.appendChild(empty)}
    for(let day=1;day<=daysInMonth;day++){
        const cell=document.createElement('div');
        cell.className='calendar-date';
        cell.textContent=day;
        if(day===today)cell.classList.add('today');
        if([15,20,22,28].includes(day))cell.classList.add('has-event');
        if([15,22].includes(day))cell.classList.add('test');
        if([20].includes(day))cell.classList.add('homework');
        if([28].includes(day))cell.classList.add('exam');
        container.appendChild(cell);
    }
}

