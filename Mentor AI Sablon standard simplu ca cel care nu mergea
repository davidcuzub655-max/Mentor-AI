        <span className="text-lg font-extrabold text-amber-400">{userData.coins.toLocaleString()} Mentor Coins</span>
      </div>
      <div className="flex gap-2 px-5 mb-4 overflow-x-auto pb-2">
        {[{ id: 'school', icon: '🏫', label: 'Scoala' },{ id: 'city', icon: '🏙️', label: 'Oras' },{ id: 'national', icon: '🇷🇴', label: 'National' }].map(tab => (
          <button key={tab.id} onClick={() => setActiveTab(tab.id)} className={"px-4 py-2 rounded-full text-xs font-semibold whitespace-nowrap transition " + (activeTab === tab.id ? 'gradient-primary text-white' : 'bg-bg-card border border-white/10 text-slate-400 hover:text-white')}>{tab.icon} {tab.label}</button>
        ))}
      </div>
      <div className="px-5 mb-6">
        {leaderboardData[activeTab].map((item, i) => (
          <div key={i} className={"flex items-center gap-3.5 py-3 border-b border-white/5 last:border-0 " + (item.you ? 'bg-secondary/10 -mx-5 px-5 rounded-xl border-0 mb-2' : '')}>
            <div className={"w-8 text-center text-base font-extrabold " + (item.rank === 1 ? 'text-yellow-400' : item.rank === 2 ? 'text-slate-300' : item.rank === 3 ? 'text-amber-600' : '')}>{item.rank}</div>
            <div className="w-10 h-10 rounded-full gradient-primary flex items-center justify-center text-sm font-bold">{item.avatar}</div>
            <div className="flex-1 min-w-0"><div className="text-sm font-semibold truncate">{item.name}</div><div className="text-[11px] text-slate-500 truncate">{item.school}</div></div>
            <div className="text-sm font-bold text-secondary">{item.xp} XP</div>
          </div>
        ))}
      </div>
      <div className="px-5 mb-4">
        <div className="flex justify-between items-center mb-3"><span className="text-base font-bold">Magazin Mentor</span><span className="text-[13px] text-secondary font-semibold cursor-pointer">Vezi tot</span></div>
        <div className="grid grid-cols-2 gap-3">
          {shopItems.map(item => (
            <button key={item.id} onClick={() => buyItem(item)} className="bg-bg-card rounded-2xl p-4 text-center border border-white/5 hover:border-secondary hover:-translate-y-1 transition">
              <div className="w-20 h-20 mx-auto mb-3 rounded-xl bg-bg-input flex items-center justify-center text-4xl">{item.icon}</div>
              <div className="text-[13px] font-semibold mb-1">{item.name}</div>
              <div className="flex items-center justify-center gap-1 text-sm font-bold text-amber-400"><i className="fas fa-coins text-xs"></i> {item.price}</div>
            </button>
          ))}
        </div>
      </div>
      <div className="px-5">
        <div className="text-base font-bold mb-3">Statistici</div>
        <div className="grid grid-cols-2 gap-3">
          {[{ icon: 'fa-book', color: 'bg-blue-500/15 text-blue-400', title: 'Capitole', value: '47' },{ icon: 'fa-check-circle', color: 'bg-emerald-500/15 text-emerald-400', title: 'Teste', value: '128' },{ icon: 'fa-trophy', color: 'bg-secondary/15 text-violet-400', title: 'Badge-uri', value: '15' },{ icon: 'fa-star', color: 'bg-amber-500/15 text-amber-400', title: 'Medie', value: '9.2' }].map((card, i) => (
            <div key={i} className="bg-bg-card rounded-2xl p-4 border border-white/5">
              <div className={"w-10 h-10 rounded-xl flex items-center justify-center text-lg mb-3 " + card.color}><i className={"fas " + card.icon}></i></div>
              <div className="text-[13px] font-semibold mb-1">{card.title}</div>
              <div className="text-xl font-extrabold">{card.value}</div>
            </div>
          ))}
        </div>
      </div>
      <div className="px-5 mt-6 mb-8">
        <button onClick={() => {
          if (confirm('Esti sigur ca vrei sa resetezi contul? Toate progresele vor fi pierdute!')) {
            onReset();
          }
        }} className="w-full py-4 rounded-xl border-2 border-red-500/30 text-red-400 font-semibold hover:bg-red-500/10 hover:border-red-500/50 transition flex items-center justify-center gap-2">
          <i className="fas fa-trash-alt"></i> Resetare cont
        </button>
      </div>
    </div>
  );
};

const App = () => {
  const [screen, setScreen] = useState('splash');
  const [navScreen, setNavScreen] = useState('home');
  const [toast, setToast] = useState(null);
  const [onboardingStep, setOnboardingStep] = useState(0);
  const [onboardingData, setOnboardingData] = useState({});

  const defaultUserData = {
    name: '',
    surname: '',
    level: 1,
    xp: 0,
    coins: 0,
    streak: 0,
    score: 0,
    totalHours: 0,
    school: '',
    class: '',
    profile: '',
    exam: '',
    dailyHours: '',
    isLoggedIn: false,
    hasCompletedOnboarding: false
  };

  const [userData, setUserData] = useState(() => {
    const saved = loadData();
    return saved || defaultUserData;
  });

  useEffect(() => { saveData(userData); }, [userData]);

  const showToast = useCallback((message, type = 'success') => { setToast({ message, type }); }, []);

  const handleSplashFinish = () => { 
    if (userData.hasCompletedOnboarding && userData.isLoggedIn) {
      setScreen('home');
      setNavScreen('home');
    } else {
      setScreen('auth');
    }
  };

  const handleLogin = () => {
    setUserData({ ...userData, isLoggedIn: true });
    setScreen('home');
    setNavScreen('home');
    showToast('Bun venit!', 'success');
  };

  const handleRegister = (formData) => {
    const nameParts = (formData.name || '').split(' ');
    setUserData({
      ...userData,
      name: nameParts[0] || '',
      surname: nameParts.slice(1).join(' ') || '',
      school: formData.school || '',
      class: formData.class || '',
      isLoggedIn: true
    });
    setOnboardingStep(1);
    setScreen('onboarding');
  };

  const handleOnboardingNext = () => {
    if (onboardingStep >= 5) {
      setUserData(prev => ({ ...prev, isLoggedIn: true, hasCompletedOnboarding: true }));
      setScreen('home');
      setNavScreen('home');
      showToast('Bun venit, ' + (userData.name || 'elev') + '! Profilul tau este gata.', 'success');
    } else {
      setOnboardingStep(onboardingStep + 1);
    }
  };

  const handleOnboardingBack = () => {
    if (onboardingStep > 1) {
      setOnboardingStep(onboardingStep - 1);
    } else {
      setScreen('register');
    }
  };

  const handleNavigate = (target) => {
    setNavScreen(target);
    const map = { home: 'home', professor: 'professor', learn: 'learnType', calendar: 'calendar', profile: 'profile' };
    setScreen(map[target] || target);
  };

  const handleStartLearn = (type) => {
    setScreen('timer');
  };

  const handleTimerFinish = () => {
    setUserData(prev => ({
      ...prev,
      coins: (prev.coins || 0) + 25,
      totalHours: (prev.totalHours || 0) + 0.5,
      xp: (prev.xp || 0) + 50,
      score: Math.min(100, (prev.score || 0) + 5)
    }));
    setScreen('report');
  };

  const onboardingSteps = [
    {
      step: 1, title: 'Cum te cheama?', desc: 'AI-ul tau personal vrea sa stie cum sa te strige.',
      options: [], isInput: true, inputKey: 'name', progress: 20
    },
    {
      step: 2, title: 'Ce clasa esti?', desc: 'Personalizam continutul in functie de anul tau de studiu.',
      options: [
        { icon: 'fa-child', label: 'Clasele V-VIII', value: 'gimnaziu' },
        { icon: 'fa-user-graduate', label: 'Clasele IX-XII', value: 'liceu' },
        { icon: 'fa-university', label: 'Facultate', value: 'facultate' }
      ],
      inputKey: 'grade', progress: 40
    },
    {
      step: 3, title: 'Ce profil ai?', desc: 'Alege profilul tau pentru materii personalizate.',
      options: [
        { icon: 'fa-flask', label: 'Real (Mate-Info)', value: 'mate-info' },
        { icon: 'fa-calculator', label: 'Real (Stiinte)', value: 'stiinte' },
        { icon: 'fa-book', label: 'Uman (Filologie)', value: 'filologie' },
        { icon: 'fa-globe', label: 'Uman (Socio-Uman)', value: 'socio-uman' }
      ],
      inputKey: 'profile', progress: 60
    },
    {
      step: 4, title: 'Ce examen urmeaza?', desc: 'Te ajutam sa te pregatesti strategic.',
      options: [
        { icon: 'fa-clipboard-check', label: 'Evaluare Nationala', value: 'evaluare' },
        { icon: 'fa-graduation-cap', label: 'BAC', value: 'bac' },
        { icon: 'fa-door-open', label: 'Admitere facultate', value: 'admitere' },
        { icon: 'fa-book-open', label: 'Niciun examen momentan', value: 'none' }
      ],
      inputKey: 'exam', progress: 80
    },
    {
      step: 5, title: 'Cate ore poti invata zilnic?', desc: 'Cream un plan personalizat pentru tine.',
      options: [
        { icon: 'fa-clock', label: '30 minute', value: '0.5' },
        { icon: 'fa-clock', label: '1 ora', value: '1' },
        { icon: 'fa-clock', label: '2 ore', value: '2' },
        { icon: 'fa-clock', label: '3+ ore', value: '3' }
      ],
      inputKey: 'dailyHours', progress: 100
    }
  ];

  const currentOnboarding = onboardingSteps[onboardingStep - 1];

  const handleReset = () => {
    localStorage.removeItem(STORAGE_KEY);
    setUserData(defaultUserData);
    setOnboardingStep(0);
    setOnboardingData({});
    setNavScreen('home');
    setScreen('auth');
    showToast('Contul a fost resetat cu succes!', 'success');
  };

  const renderScreen = () => {
    switch (screen) {
      case 'splash':
        return <SplashScreen onFinish={handleSplashFinish} />;
      case 'auth':
        return <AuthScreen onLogin={() => setScreen('login')} onRegister={() => setScreen('register')} />;
      case 'login':
        return <LoginScreen onBack={() => setScreen('auth')} onLogin={handleLogin} />;
      case 'register':
        return <RegisterScreen onBack={() => setScreen('auth')} onContinue={handleRegister} />;
      case 'onboarding':
        return currentOnboarding.isInput ? (
          <div className="min-h-screen flex flex-col px-6 pt-10 pb-24 animate-fadeIn">
            <div className="mb-8">
              <div className="text-xs text-secondary font-bold uppercase tracking-wider mb-2">Pasul {currentOnboarding.step} din 5</div>
              <h2 className="text-2xl font-extrabold mb-2">{currentOnboarding.title}</h2>
              <p className="text-sm text-slate-400 leading-relaxed">{currentOnboarding.desc}</p>
            </div>
            <input type="text" value={onboardingData.name || ''} onChange={e => setOnboardingData({...onboardingData, name: e.target.value})}
              className="w-full py-4 px-5 bg-bg-input border-[1.5px] border-white/10 rounded-xl text-white text-lg text-center outline-none focus:border-secondary transition placeholder:text-slate-600"
              placeholder="Numele tau" />
            <div className="mt-auto pt-6">
              <div className="w-full h-1.5 bg-white/10 rounded-full overflow-hidden mb-4">
                <div className="h-full gradient-primary rounded-full transition-all" style={{width: currentOnboarding.progress + '%'}}></div>
              </div>
              <button onClick={handleOnboardingNext} className="w-full py-4 rounded-xl gradient-primary text-white font-semibold flex items-center justify-center gap-3 shadow-[0_4px_20px_rgba(124,58,237,0.4)] hover:-translate-y-0.5 transition">
                Continua <i className="fas fa-arrow-right"></i>
              </button>
            </div>
          </div>
        ) : (
          <OnboardingScreen
            step={currentOnboarding.step}
            total={5}
            title={currentOnboarding.title}
            desc={currentOnboarding.desc}
            options={currentOnboarding.options}
            selected={onboardingData[currentOnboarding.inputKey]}
            onSelect={(opt) => setOnboardingData({...onboardingData, [currentOnboarding.inputKey]: opt.value})}
            onNext={handleOnboardingNext}
            onBack={handleOnboardingBack}
            isLast={onboardingStep === 5}
            progress={currentOnboarding.progress}
          />
        );
      case 'home':
        return <HomeScreen userData={userData} onNavigate={handleNavigate} />;
      case 'professor':
        return <ProfessorScreen onNavigate={handleNavigate} onToast={showToast} />;
      case 'learnType':
        return <LearnTypeScreen onStart={handleStartLearn} />;
      case 'timer':
        return <TimerScreen onFinish={handleTimerFinish} onToast={showToast} />;
      case 'report':
        return <ReportScreen onHome={() => { setScreen('home'); setNavScreen('home'); }} onToast={showToast} />;
      case 'calendar':
        return <CalendarScreen userData={userData} />;
      case 'profile':
        return <ProfileScreen userData={userData} onUpdate={setUserData} onToast={showToast} onReset={handleReset} />;
      default:
        return <HomeScreen userData={userData} onNavigate={handleNavigate} />;
    }
  };

  const showNav = ['home', 'professor', 'learnType', 'calendar', 'profile'].includes(screen);

  return (
    <div className="max-w-[480px] mx-auto min-h-screen relative bg-bg overflow-hidden">
      <svg width="0" height="0" className="absolute">
        <defs>
          <linearGradient id="scoreGradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stopColor="#7c3aed" />
            <stop offset="100%" stopColor="#a78bfa" />
          </linearGradient>
          <linearGradient id="timerGradient" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stopColor="#7c3aed" />
            <stop offset="100%" stopColor="#3b82f6" />
          </linearGradient>
        </defs>
      </svg>

      {renderScreen()}

      {showNav && <BottomNav active={navScreen} onNavigate={handleNavigate} />}

      {toast && <Toast message={toast.message} type={toast.type} onClose={() => setToast(null)} />}
    </div>
  );
};

const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(<App />);
</script>
</body>
</html>
