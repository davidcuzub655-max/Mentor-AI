        <div className="w-full h-2.5 bg-white/10 rounded-full overflow-hidden mb-2"><div className="h-full gradient-primary rounded-full relative transition-all duration-1000" style={{width: '0%'}}><div className="absolute right-0 top-0 bottom-0 w-5 bg-gradient-to-r from-transparent to-white/30 rounded-full"></div></div></div>
