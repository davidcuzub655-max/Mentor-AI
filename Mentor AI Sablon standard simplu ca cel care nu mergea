        {sounds.map(s => (
          <button key={s.id} onClick={() => setSound(s.id)} className={"px-4 py-2 rounded-full text-xs font-semibold transition border " + (sound === s.id ? 'bg-secondary text-white border-secondary' : 'bg-bg-card text-slate-400 border-white/10 hover:bg-secondary/20')}><i className={"fas " + s.icon + " mr-1.5"}></i>{s.label}</button>
        ))}
      </div>
    </div>
  );
};

