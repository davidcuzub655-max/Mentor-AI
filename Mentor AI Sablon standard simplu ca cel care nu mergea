const RegisterScreen = ({ onBack, onContinue }) => {
  const [form, setForm] = useState({ name: '', phone: '', email: '', school: '', class: '', password: '' });
  const handleSubmit = () => { if (!form.name || !form.email) { alert('Completeaza numele si emailul!'); return; } onContinue(form); };
