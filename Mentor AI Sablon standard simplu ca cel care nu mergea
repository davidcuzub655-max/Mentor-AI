    <div className="min-h-screen flex flex-col items-center px-6 pt-12 pb-24 animate-fadeIn">
      <div className="w-20 h-20 gradient-primary rounded-[22px] flex items-center justify-center text-4xl font-black text-white mb-6">M</div>
      <h1 className="text-[26px] font-extrabold mb-2">Creeaza cont</h1>
