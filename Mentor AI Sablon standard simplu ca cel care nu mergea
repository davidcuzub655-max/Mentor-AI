        {[{ icon: 'fa-clock', color: 'bg-blue-500/15 text-blue-400', title: 'Ore azi', value: '0h', sub: 'Incepe sa inveti' },{ icon: 'fa-coins', color: 'bg-emerald-500/15 text-emerald-400', title: 'Mentor Coins', value: (userData.coins || 0).toLocaleString(), sub: 'Câstiga coins invatand' },{ icon: 'fa-trophy', color: 'bg-secondary/15 text-violet-400', title: 'Clasament', value: '--', sub: 'Completeaza lectii' },{ icon: 'fa-piggy-bank', color: 'bg-amber-500/15 text-amber-400', title: 'Economisit', value: '0 lei', sub: 'Incepe sa economisesti' }].map((card, i) => (
