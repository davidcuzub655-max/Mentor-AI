<script type="text/babel">

const { useState, useEffect, useRef, useCallback } = React;

const STORAGE_KEY = 'mentor_ai_data';
const loadData = () => { const saved = localStorage.getItem(STORAGE_KEY); return saved ? JSON.parse(saved) : null; };
const saveData = (data) => { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); };
const generateId = () => Math.random().toString(36).substr(2, 9);
const formatTime = (seconds) => { 
  const m = Math.floor(seconds / 60).toString().padStart(2, '0'); 
  const s = (seconds % 60).toString().padStart(2, '0'); 
  return m + ':' + s; 
};

const AI_RESPONSES = {
  default: [
    "Excelenta intrebare! Haide sa vedem impreuna cum putem aborda acest subiect.",
    "Inteleg unde vrei sa ajungi. Iata o explicatie pas cu pas:",
    "Foarte bine ca intrebi! Acest concept este fundamental.",
    "Haide sa descompunem problema in pasi mici si usor de inteles.",
    "Perfect! Voi crea un rezumat vizual pentru tine."
  ],
  math: [
    "Pentru aceasta problema de matematica, incepe prin a identifica datele cunoscute.",
    "Aplica formula generala si verifica fiecare pas. Ai incredere in proces!",
    "Graficul functiei iti va arata comportamentul in jurul punctului critic."
  ],
  biology: [
    "ADN-ul contine informatia genetica organizata in gene. Fiecare gena codifica o proteina.",
    "Replicarea ADN-ului este semi-conservativa.",
    "Mitocondriile sunt centrale energetice ale celulei."
  ],
  physics: [
    "Legea lui Ohm: V = I x R. Tensiunea este direct proportionala cu curentul.",
    "Energia cinetica depinde de masa si viteza: Ec = mv^2/2.",
    "Campul electromagnetic se propaga cu viteza luminii in vid."
  ],
  romanian: [
    "Analizeaza textul identificand tema, ideea poetica si motivele literare.",
    "Figurile de stil imbogatesc expresivitatea textului.",
    "In romanul interbelic, personajul este adesea un individ in conflict cu societatea."
  ]
};

const getAIResponse = (message) => {
  const lower = message.toLowerCase();
  let category = 'default';
  if (lower.includes('mate') || lower.includes('algebra') || lower.includes('geometrie') || lower.includes('integral')) category = 'math';
  else if (lower.includes('bio') || lower.includes('adn') || lower.includes('celul') || lower.includes('genetic')) category = 'biology';
  else if (lower.includes('fizic') || lower.includes('electro') || lower.includes('energie') || lower.includes('forta')) category = 'physics';
  else if (lower.includes('romana') || lower.includes('poezie') || lower.includes('roman') || lower.includes('liter')) category = 'romanian';
  const responses = AI_RESPONSES[category];
  return responses[Math.floor(Math.random() * responses.length)];
};

const Toast = ({ message, type, onClose }) => {
  useEffect(() => { const timer = setTimeout(onClose, 3000); return () => clearTimeout(timer); }, [onClose]);
  const icons = { success: 'fa-check-circle', warning: 'fa-exclamation-triangle', info: 'fa-info-circle' };
  const colors = { success: 'text-emerald-400', warning: 'text-amber-400', info: 'text-blue-400' };
  return (
    <div className="fixed top-5 left-1/2 -translate-x-1/2 z-[10001] animate-slideUp">
      <div className="bg-bg-card border border-white/10 rounded-xl px-5 py-3.5 flex items-center gap-3 shadow-2xl">
        <i className={"fas " + icons[type] + " " + colors[type] + " text-xl"}></i>
        <span className="text-sm font-semibold">{message}</span>
      </div>
    </div>
  );
};

