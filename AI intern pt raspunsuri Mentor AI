    <script>
        // Tab switching
        function switchTab(tabName) {
            // Hide all contents
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));

            // Show selected
            document.getElementById('tab-' + tabName).classList.add('active');
            event.target.classList.add('active');
        }

        // Demo responses for AI Mentor
        const demoResponses = {
            'matematica': [
                "Hmmm, această ecuație pare interesantă! 🧮 Înainte să îți dau vreun indiciu, spune-mi: ce operații inverse știi tu? Dacă ai un număr care se adună cu 5, cum îl 'anulezi'?",
                "Foarte bine! Acum, dacă ai 2x = 8, ce crezi că înseamnă acel '2' lângă x? Cum 'desfaci' înmulțirea?",
                "Exact! Împărțirea este inversa înmulțirii. Deci x = 8 ÷ 2 = 4. Bravo că ai descoperit singur! 🎉 Verifică: 2×4 + 5 = 13?"
            ],
            'romana': [
                "Ce personaj interesant! 📖 Înainte să analizăm, gândește-te: ce acțiuni face acest personaj în primele 3 capitole? Cum ar descrie un prieten acțiunile lui?",
                "Bună observație! Acum, dacă personajul tău ar sta de vorbă cu un prieten, ce i-ar spune despre visul lui? Încearcă să îl descrii în 3 cuvinte."
            ],
            'fizica': [
                "O problemă interesantă de cinematica! ⚡ Înainte să începem, ce formule știi tu despre mișcarea uniformă? Care sunt cele 3 mărimi fundamentale și cum se leagă ele?",
                "Corect! Viteza = distanță / timp. Acum, uită-te la datele problemei: ce știi și ce trebuie să afli? Încearcă să le notezi pe o hârtie."
            ],
            'evaluare': [
                "Pregătire pentru Evaluarea Națională! 📝 Foarte bine că exersezi. Pentru acest tip de subiect, ce structură îți cere baremul? Câte argumente trebuie să ai minim?",
                "Bravo! Acum, gândește-te: care este opinia ta personală despre text? Încearcă să o exprimi în propoziția ta, nu doar să reproduc ce spune autorul."
            ],
            'bac': [
                "Pregătire Bacalaureat! 🎓 Acest tip de eseu necesită o structură clară. Ce știi despre structura unei compuneri argumentative? Care sunt cele 3 părți obligatorii?",
                "Excelent! Acum, pentru partea a II-a, cum ai identifica trăsăturile personajului? Ce citate ai putea selecta din text pentru a-ți susține argumentul?"
            ],
            'default': [
                "O întrebare excelentă! 💡 Înainte să explorăm răspunsul, ce știi TU deja despre acest subiect? Încearcă să îmi spui 3 lucruri pe care le-ai învățat la școală.",
                "Super! Acum, gândește-te: cum ai explica acest concept unui prieten care nu a fost la școală azi? Încearcă să folosești cuvintele tale.",
                "Aproape! 🎯 Îți dau un indiciu final: uită-te la pagina 47 din manual. Ce diagramă vezi acolo? Cum se leagă de întrebarea ta?"
            ]
        };

        let demoStep = 0;

        function sendMessage() {
            const input = document.getElementById('chat-input');
            const messages = document.getElementById('chat-messages');
            const subject = document.getElementById('subject-select').value;
            const text = input.value.trim();

            if (!text) return;

            // Add user message
            const userDiv = document.createElement('div');
            userDiv.className = 'message user';
            userDiv.innerHTML = `<strong>Elev:</strong> ${escapeHtml(text)}`;
            messages.appendChild(userDiv);

            input.value = '';
            messages.scrollTop = messages.scrollHeight;

            // Add typing indicator
            const typingDiv = document.createElement('div');
            typingDiv.className = 'message ai';
            typingDiv.id = 'typing-indicator';
            typingDiv.innerHTML = `
                <div class="typing-indicator">
                    <div class="typing-dot"></div>
                    <div class="typing-dot"></div>
                    <div class="typing-dot"></div>
                </div>
            `;
            messages.appendChild(typingDiv);
            messages.scrollTop = messages.scrollHeight;

            // Simulate AI thinking
            setTimeout(() => {
                // Remove typing indicator
                const indicator = document.getElementById('typing-indicator');
                if (indicator) indicator.remove();

                const aiDiv = document.createElement('div');
                aiDiv.className = 'message ai';

                const responses = demoResponses[subject] || demoResponses['default'];
                const response = responses[demoStep % responses.length];
                demoStep++;

                aiDiv.innerHTML = `<strong>🤖 Mentor AI:</strong><br>${response}<br><br><span style="font-size: 11px; color: #94a3b8;">💡 Sfat: Încearcă să scrii răspunsul tău în caiet, apoi revino cu ce ai descoperit!</span>`;
                messages.appendChild(aiDiv);
                messages.scrollTop = messages.scrollHeight;
            }, 800 + Math.random() * 600);
        }

        function analyzeAI() {
            const input = document.getElementById('detector-input').value.trim();
            if (!input) {
                alert('Te rog să introduci text pentru analiză!');
                return;
            }

            const results = document.getElementById('detector-results');
            results.classList.add('show');

            // Reset
            document.getElementById('score-claude').textContent = '--%';
            document.getElementById('score-gpt').textContent = '--%';
            document.getElementById('score-gemini').textContent = '--%';
            document.getElementById('score-avg').textContent = '--%';
            document.getElementById('score-bar').style.width = '0%';
            document.getElementById('detector-verdict').textContent = '';

            // Calculate pseudo-realistic scores based on text characteristics
            const textLength = input.length;
            const hasComplexWords = /\b(efemer|paradigm|hegemonie|dialectic|pragmatic|empiric|axiomatic|hermeneutic|ontologic|epistemologic|sintagma|polisemantic|metaforic|aliteratie|prosodie|enjambement)\b/i.test(input);
            const hasRepetitivePatterns = (input.match(/\b(\w+)\b.*\b\1\b/gi) || []).length > 3;
            const hasPerfectGrammar = !/[,.]\s*[a-z]/.test(input) && !/\s{2,}/.test(input);
            const hasChildlikeMistakes = /[,.]\s*[a-z]/.test(input) || /\s{2,}/.test(input) || /(am facut|am mers|am vazut|am spus|am luat)\b/i.test(input);
            const hasAdvancedVocabulary = (input.match(/\b\w{12,}\b/g) || []).length > 2;

            // Calculate base score
            let baseScore = 30 + Math.random() * 40;
            if (hasComplexWords) baseScore += 15;
            if (hasRepetitivePatterns) baseScore += 10;
            if (hasPerfectGrammar && textLength > 200) baseScore += 10;
            if (hasAdvancedVocabulary) baseScore += 12;
            if (textLength < 50) baseScore -= 20;
            if (hasChildlikeMistakes) baseScore -= 25;

            const claudeScore = Math.min(95, Math.max(5, Math.round(baseScore + (Math.random() - 0.5) * 20)));
            const gptScore = Math.min(95, Math.max(5, Math.round(baseScore + (Math.random() - 0.5) * 15)));
            const geminiScore = Math.min(95, Math.max(5, Math.round(baseScore + (Math.random() - 0.5) * 25)));
            const avgScore = Math.round((claudeScore + gptScore + geminiScore) / 3);

            // Animate scores with delays
            setTimeout(() => {
                document.getElementById('score-claude').textContent = claudeScore + '%';
                document.getElementById('score-claude').style.color = claudeScore > 60 ? '#ef4444' : claudeScore > 30 ? '#fbbf24' : '#34d399';
            }, 300);

            setTimeout(() => {
                document.getElementById('score-gpt').textContent = gptScore + '%';
                document.getElementById('score-gpt').style.color = gptScore > 60 ? '#ef4444' : gptScore > 30 ? '#fbbf24' : '#34d399';
            }, 600);

            setTimeout(() => {
                document.getElementById('score-gemini').textContent = geminiScore + '%';
                document.getElementById('score-gemini').style.color = geminiScore > 60 ? '#ef4444' : geminiScore > 30 ? '#fbbf24' : '#34d399';
            }, 900);

            setTimeout(() => {
                document.getElementById('score-avg').textContent = avgScore + '%';
                document.getElementById('score-bar').style.width = avgScore + '%';

                let verdict = '';
                if (avgScore < 20) {
                    verdict = '✅ <strong>Text autentic (uman)</strong> — Scor foarte scăzut de AI. Stilul de scriere este natural, cu variații specifice unui elev. Se recomandă continuarea încurajării scrisului original.';
                } else if (avgScore < 50) {
                    verdict = '⚠️ <strong>Posibil amestec</strong> — Textul conține elemente care pot fi atât umane, cât și AI. Se recomandă discuție cu elevul pentru a clarifica procesul de scriere. Poate fi vorba de corectare gramaticală cu AI.';
                } else if (avgScore < 75) {
                    verdict = '🔶 <strong>Probabil generat de AI</strong> — Structura, vocabularul și coerența sugerează generare AI semnificativă. Se recomandă reverificarea cu întrebări orale despre conținut.';
                } else {
                    verdict = '🔴 <strong>Text generat de AI</strong> — Scor foarte ridicat. Vocabular academic necaracteristic, structură perfectă, și lipsă de variații stilistice specifice vârstei. Intervenție pedagogică necesară.';
                }

                document.getElementById('detector-verdict').innerHTML = verdict;
            }, 1200);
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
    </script>
