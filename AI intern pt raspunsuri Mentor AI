<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mentor AI România - Platformă Educațională</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            min-height: 100vh;
            color: #f8fafc;
            line-height: 1.6;
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 24px;
        }

        /* Header */
        .header {
            text-align: center;
            margin-bottom: 32px;
        }

        .header-inner {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 8px;
        }

        .logo-icon {
            width: 48px;
            height: 48px;
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }

        .header h1 {
            margin: 0;
            font-size: 28px;
            font-weight: 700;
            background: linear-gradient(90deg, #60a5fa, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .header p {
            margin: 0;
            color: #94a3b8;
            font-size: 15px;
        }

        /* Tab Navigation */
        .tab-nav {
            display: flex;
            gap: 8px;
            margin-bottom: 24px;
            background: rgba(30, 41, 59, 0.8);
            padding: 6px;
            border-radius: 12px;
            border: 1px solid #334155;
        }

        .tab-btn {
            flex: 1;
            padding: 10px 16px;
            border: none;
            border-radius: 8px;
            background: transparent;
            color: #94a3b8;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 13px;
            font-family: inherit;
        }

        .tab-btn:hover {
            color: #e2e8f0;
        }

        .tab-btn.active {
            background: #3b82f6;
            color: white;
        }

        /* Tab Content */
        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        /* Cards */
        .card {
            background: rgba(30, 41, 59, 0.6);
            border: 1px solid #334155;
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 16px;
        }

        .card-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
            margin-bottom: 24px;
        }

        .feature-card {
            border-radius: 16px;
            padding: 20px;
            border: 1px solid;
        }

        .feature-card.blue {
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(139, 92, 246, 0.15));
            border-color: #3b82f6;
        }

        .feature-card.red {
            background: linear-gradient(135deg, rgba(239, 68, 68, 0.15), rgba(249, 115, 22, 0.15));
            border-color: #ef4444;
        }

        .feature-card h3 {
            margin: 0 0 8px 0;
            font-size: 16px;
        }

        .feature-card.blue h3 {
            color: #60a5fa;
        }

        .feature-card.red h3 {
            color: #f87171;
        }

        .feature-card p {
            margin: 0;
            font-size: 13px;
            color: #cbd5e1;
            line-height: 1.5;
        }

        .feature-icon {
            font-size: 32px;
            margin-bottom: 8px;
        }

        /* Tech Stack */
        .tech-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            background: rgba(15, 23, 42, 0.6);
            border-radius: 10px;
            margin-bottom: 12px;
            border-left: 3px solid;
        }

        .tech-item:last-child {
            margin-bottom: 0;
        }

        .tech-item.blue {
            border-left-color: #3b82f6;
        }

        .tech-item.purple {
            border-left-color: #8b5cf6;
        }

        .tech-item.green {
            border-left-color: #10b981;
        }

        .tech-item.orange {
            border-left-color: #f59e0b;
        }

        .tech-icon {
            font-size: 20px;
        }

        .tech-title {
            font-weight: 600;
            font-size: 14px;
        }

        .tech-desc {
            font-size: 12px;
            color: #94a3b8;
        }

        /* Flow Diagram */
        .flow-step {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px;
            border-radius: 10px;
            border: 1px solid;
            margin-bottom: 0;
        }

        .flow-connector {
            height: 20px;
            width: 2px;
            background: #475569;
            margin-left: 24px;
        }

        .step-number {
            width: 24px;
            height: 24px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 700;
            color: white;
            flex-shrink: 0;
        }

        .step-text {
            font-size: 13px;
        }

        .step-text strong {
            color: #e2e8f0;
        }

        /* Chat Interface */
        .chat-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 16px;
        }

        .chat-avatar {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .chat-status {
            font-size: 12px;
            color: #34d399;
        }

        .chat-messages {
            display: flex;
            flex-direction: column;
            gap: 12px;
            max-height: 400px;
            overflow-y: auto;
            margin-bottom: 16px;
            padding: 4px;
        }

        .message {
            max-width: 85%;
            padding: 14px 16px;
            border-radius: 16px;
            font-size: 13px;
            line-height: 1.6;
        }

        .message.ai {
            align-self: flex-start;
            background: rgba(59, 130, 246, 0.15);
            border: 1px solid rgba(59, 130, 246, 0.3);
            border-radius: 16px 16px 16px 4px;
            color: #e2e8f0;
        }

        .message.user {
            align-self: flex-end;
            background: rgba(16, 185, 129, 0.15);
            border: 1px solid rgba(16, 185, 129, 0.3);
            border-radius: 16px 16px 4px 16px;
            color: #e2e8f0;
        }

        .chat-input-area {
            display: flex;
            gap: 10px;
            align-items: flex-end;
        }

        .chat-input-area select,
        .chat-input-area input {
            background: rgba(15, 23, 42, 0.8);
            border: 1px solid #475569;
            border-radius: 10px;
            padding: 10px 12px;
            color: #e2e8f0;
            font-size: 13px;
            outline: none;
            font-family: inherit;
        }

        .chat-input-area select {
            cursor: pointer;
        }

        .chat-input-area input {
            flex: 1;
        }

        .chat-input-area input::placeholder {
            color: #64748b;
        }

        .btn-send {
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            border: none;
            border-radius: 10px;
            padding: 10px 18px;
            color: white;
            font-weight: 600;
            cursor: pointer;
            font-size: 13px;
            white-space: nowrap;
            font-family: inherit;
            transition: opacity 0.2s;
        }

        .btn-send:hover {
            opacity: 0.9;
        }

        .safety-badges {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .safety-badge {
            flex: 1;
            min-width: 200px;
            border-radius: 10px;
            padding: 12px 16px;
            display: flex;
            align-items: center;
            gap: 10px;
            border: 1px solid;
        }

        .safety-badge.green {
            background: rgba(16, 185, 129, 0.1);
            border-color: rgba(16, 185, 129, 0.3);
        }

        .safety-badge.orange {
            background: rgba(245, 158, 11, 0.1);
            border-color: rgba(245, 158, 11, 0.3);
        }

        .safety-badge .icon {
            font-size: 20px;
        }

        .safety-badge .title {
            font-weight: 600;
            font-size: 13px;
        }

        .safety-badge.green .title {
            color: #34d399;
        }

        .safety-badge.orange .title {
            color: #fbbf24;
        }

        .safety-badge .desc {
            font-size: 11px;
            color: #94a3b8;
        }

        /* Detector */
        .detector-textarea {
            width: 100%;
            min-height: 150px;
            background: rgba(15, 23, 42, 0.8);
            border: 1px solid #475569;
            border-radius: 12px;
            padding: 14px;
            color: #e2e8f0;
            font-size: 14px;
            line-height: 1.6;
            outline: none;
            resize: vertical;
            font-family: inherit;
        }

        .detector-textarea::placeholder {
            color: #64748b;
        }

        .detector-actions {
            display: flex;
            gap: 10px;
            margin-top: 14px;
            align-items: center;
        }

        .btn-analyze {
            background: linear-gradient(135deg, #ef4444, #f97316);
            border: none;
            border-radius: 10px;
            padding: 12px 24px;
            color: white;
            font-weight: 600;
            cursor: pointer;
            font-size: 14px;
            font-family: inherit;
            transition: opacity 0.2s;
        }

        .btn-analyze:hover {
            opacity: 0.9;
        }

        .detector-engines {
            font-size: 12px;
            color: #94a3b8;
        }

        .detector-results {
            display: none;
        }

        .detector-results.show {
            display: block;
        }

        .score-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 16px;
        }

        .score-card {
            border-radius: 12px;
            padding: 16px;
            text-align: center;
            border: 1px solid;
        }

        .score-card.claude {
            background: rgba(239, 68, 68, 0.1);
            border-color: rgba(239, 68, 68, 0.3);
        }

        .score-card.gpt {
            background: rgba(59, 130, 246, 0.1);
            border-color: rgba(59, 130, 246, 0.3);
        }

        .score-card.gemini {
            background: rgba(16, 185, 129, 0.1);
            border-color: rgba(16, 185, 129, 0.3);
        }

        .score-icon {
            font-size: 28px;
            margin-bottom: 4px;
        }

        .score-label {
            font-size: 12px;
            color: #94a3b8;
            margin-bottom: 4px;
        }

        .score-value {
            font-size: 24px;
            font-weight: 700;
        }

        .score-card.claude .score-value {
            color: #f87171;
        }

        .score-card.gpt .score-value {
            color: #60a5fa;
        }

        .score-card.gemini .score-value {
            color: #34d399;
        }

        .avg-panel {
            background: rgba(30, 41, 59, 0.8);
            border: 1px solid #334155;
            border-radius: 12px;
            padding: 16px;
        }

        .avg-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }

        .avg-label {
            font-weight: 600;
            font-size: 14px;
        }

        .avg-value {
            font-size: 20px;
            font-weight: 700;
            color: #fbbf24;
        }

        .progress-bar {
            width: 100%;
            height: 8px;
            background: rgba(15, 23, 42, 0.6);
            border-radius: 4px;
            overflow: hidden;
            margin-bottom: 12px;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #10b981, #fbbf24, #ef4444);
            border-radius: 4px;
            transition: width 1s ease;
            width: 0%;
        }

        .verdict {
            font-size: 13px;
            color: #cbd5e1;
            line-height: 1.6;
        }

        /* Curriculum */
        .curriculum-section {
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 16px;
            border: 1px solid;
        }

        .curriculum-section.primary {
            background: rgba(59, 130, 246, 0.1);
            border-color: rgba(59, 130, 246, 0.2);
        }

        .curriculum-section.gimnazial {
            background: rgba(139, 92, 246, 0.1);
            border-color: rgba(139, 92, 246, 0.2);
        }

        .curriculum-section.liceu-inf {
            background: rgba(16, 185, 129, 0.1);
            border-color: rgba(16, 185, 129, 0.2);
        }

        .curriculum-section.liceu-sup {
            background: rgba(245, 158, 11, 0.1);
            border-color: rgba(245, 158, 11, 0.2);
        }

        .curriculum-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }

        .badge {
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            color: white;
        }

        .badge.blue {
            background: #3b82f6;
        }

        .badge.purple {
            background: #8b5cf6;
        }

        .badge.green {
            background: #10b981;
        }

        .badge.orange {
            background: #f59e0b;
        }

        .badge.red {
            background: #ef4444;
        }

        .curriculum-subtitle {
            font-size: 13px;
            color: #94a3b8;
        }

        .tags {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .tag {
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 11px;
        }

        .tag.blue {
            background: rgba(59, 130, 246, 0.2);
            color: #93c5fd;
        }

        .tag.purple {
            background: rgba(139, 92, 246, 0.2);
            color: #c4b5fd;
        }

        .tag.green {
            background: rgba(16, 185, 129, 0.2);
            color: #6ee7b7;
        }

        .tag.orange {
            background: rgba(245, 158, 11, 0.2);
            color: #fcd34d;
        }

        .tag.red {
            background: rgba(239, 68, 68, 0.3);
            color: #fca5a5;
            font-weight: 600;
        }

        .profile-section {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .profile-box {
            flex: 1;
            min-width: 200px;
        }

        .profile-title {
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 6px;
        }

        .profile-title.real {
            color: #34d399;
        }

        .profile-title.uman {
            color: #a78bfa;
        }

        .profile-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 4px;
        }

        .profile-tag {
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 10px;
        }

        .profile-tag.real {
            background: rgba(16, 185, 129, 0.2);
            color: #6ee7b7;
        }

        .profile-tag.uman {
            background: rgba(139, 92, 246, 0.2);
            color: #c4b5fd;
        }

        /* Footer */
        .footer {
            margin-top: 24px;
            text-align: center;
            padding-top: 16px;
            border-top: 1px solid #334155;
        }

        .footer p {
            margin: 0;
            font-size: 12px;
            color: #64748b;
        }

        /* Section Title */
        .section-title {
            margin: 0 0 16px 0;
            font-size: 18px;
        }

        .section-title.blue {
            color: #60a5fa;
        }

        .section-title.red {
            color: #f87171;
        }

        .section-title.green {
            color: #34d399;
        }

        .section-title.yellow {
            color: #fbbf24;
        }

        /* Scrollbar */
        .chat-messages::-webkit-scrollbar {
            width: 6px;
        }

        .chat-messages::-webkit-scrollbar-track {
            background: transparent;
        }

        .chat-messages::-webkit-scrollbar-thumb {
            background: #475569;
            border-radius: 3px;
        }

        /* Responsive */
        @media (max-width: 640px) {
            .card-grid {
                grid-template-columns: 1fr;
            }

            .score-grid {
                grid-template-columns: 1fr;
            }

            .chat-input-area {
                flex-wrap: wrap;
            }

            .chat-input-area select {
                flex: 1;
            }

            .chat-input-area input {
                width: 100%;
                order: -1;
            }

            .tab-nav {
                flex-wrap: wrap;
            }

            .tab-btn {
                font-size: 12px;
                padding: 8px 12px;
            }
        }

        /* Typing indicator */
        .typing-indicator {
            display: flex;
            gap: 4px;
            padding: 8px 0;
        }

        .typing-dot {
            width: 8px;
            height: 8px;
            background: #60a5fa;
            border-radius: 50%;
            animation: typing 1.4s infinite;
        }

        .typing-dot:nth-child(2) {
            animation-delay: 0.2s;
        }

        .typing-dot:nth-child(3) {
            animation-delay: 0.4s;
        }

        @keyframes typing {
            0%, 60%, 100% {
                transform: translateY(0);
                opacity: 0.4;
            }
            30% {
                transform: translateY(-6px);
                opacity: 1;
            }
        }

        .hidden {
            display: none !important;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <div class="header-inner">
                <div class="logo-icon">🎓</div>
                <h1>Mentor AI România</h1>
            </div>
            <p>Platformă educațională AI-safe pentru elevi și părinți • Clasele I-XII</p>
        </div>

        <!-- Tab Navigation -->
        <div class="tab-nav">
            <button class="tab-btn active" onclick="switchTab('architecture')">🏗️ Arhitectură</button>
            <button class="tab-btn" onclick="switchTab('demo')">💬 Demo AI Mentor</button>
            <button class="tab-btn" onclick="switchTab('detector')">🔍 Detector AI</button>
            <button class="tab-btn" onclick="switchTab('curriculum')">📚 Curriculum</button>
        </div>

        <!-- Tab 1: Architecture -->
        <div id="tab-architecture" class="tab-content active">
            <!-- Core Features -->
            <div class="card-grid">
                <div class="feature-card blue">
                    <div class="feature-icon">🧠</div>
                    <h3>AI Mentor Pedagogic</h3>
                    <p>Nu face tema! Pune întrebări ghidate, oferă indicii, îl ajută pe copil să descopere singur soluția.</p>
                </div>
                <div class="feature-card red">
                    <div class="feature-icon">🛡️</div>
                    <h3>Detector AI Multi-Engine</h3>
                    <p>Analizează textul cu 3 AI-uri (Claude + GPT + Gemini) și detectează % de conținut generat de AI.</p>
                </div>
            </div>

            <!-- Tech Stack -->
            <div class="card">
                <h3 class="section-title yellow">⚡ Stack Tehnic Hibrid</h3>
                <div class="tech-item blue">
                    <div class="tech-icon">🌐</div>
                    <div>
                        <div class="tech-title">Frontend</div>
                        <div class="tech-desc">React/Vue + Tailwind + WebSocket real-time</div>
                    </div>
                </div>
                <div class="tech-item purple">
                    <div class="tech-icon">🔌</div>
                    <div>
                        <div class="tech-title">API Layer</div>
                        <div class="tech-desc">Node.js/Python FastAPI + Redis cache + Rate limiting</div>
                    </div>
                </div>
                <div class="tech-item green">
                    <div class="tech-icon">🤖</div>
                    <div>
                        <div class="tech-title">AI Engines (Load Balanced)</div>
                        <div class="tech-desc">Claude 3.5 Sonnet + GPT-4o + Gemini 1.5 Pro</div>
                    </div>
                </div>
                <div class="tech-item orange">
                    <div class="tech-icon">📊</div>
                    <div>
                        <div class="tech-title">Vector DB (RAG)</div>
                        <div class="tech-desc">Pinecone/Weaviate + Programe școlare PDF + Manuale oficiale</div>
                    </div>
                </div>
            </div>

            <!-- Flow Diagram -->
            <div class="card">
                <h3 class="section-title green">🔄 Flux de Lucru</h3>
                <div class="flow-step" style="background: rgba(59, 130, 246, 0.1); border-color: rgba(59,130,246,0.3);">
                    <span class="step-number" style="background: #3b82f6;">1</span>
                    <span class="step-text"><strong>Elevul pune întrebare</strong> → Sistemul verifică dacă e în curriculum</span>
                </div>
                <div class="flow-connector"></div>
                <div class="flow-step" style="background: rgba(139, 92, 246, 0.1); border-color: rgba(139,92,246,0.3);">
                    <span class="step-number" style="background: #8b5cf6;">2</span>
                    <span class="step-text"><strong>RAG Search</strong> → Caută în programele școlare și manuale PDF</span>
                </div>
                <div class="flow-connector"></div>
                <div class="flow-step" style="background: rgba(16, 185, 129, 0.1); border-color: rgba(16,185,129,0.3);">
                    <span class="step-number" style="background: #10b981;">3</span>
                    <span class="step-text"><strong>AI Mentor</strong> → Pune întrebări ghidate, NU dă răspunsul direct</span>
                </div>
                <div class="flow-connector"></div>
                <div class="flow-step" style="background: rgba(245, 158, 11, 0.1); border-color: rgba(245,158,11,0.3);">
                    <span class="step-number" style="background: #f59e0b;">4</span>
                    <span class="step-text"><strong>Copilul scrie răspunsul</strong> → Detector AI analizează autenticitatea</span>
                </div>
                <div class="flow-connector"></div>
                <div class="flow-step" style="background: rgba(239, 68, 68, 0.1); border-color: rgba(239,68,68,0.3);">
                    <span class="step-number" style="background: #ef4444;">5</span>
                    <span class="step-text"><strong>Feedback</strong> → Scor AI%, explicații, și pași următori</span>
                </div>
            </div>
        </div>

        <!-- Tab 2: Demo AI Mentor -->
        <div id="tab-demo" class="tab-content">
            <div class="card">
                <div class="chat-header">
                    <div class="chat-avatar">🤖</div>
                    <div>
                        <div style="font-weight: 600; font-size: 15px;">Mentor AI</div>
