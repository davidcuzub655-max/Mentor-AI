class PedagogicPrompts:
    """
    Prompturi sistem pentru fiecare AI engine.
    TOATE modelele sunt constrânse să NU dea răspunsul direct.
    """

    SYSTEM_PROMPT = """Ești Mentor AI, un asistent educațional pentru elevi români (clasele I-XII).

REGULI STRICTE:
1. NU dai niciodată răspunsul direct la teme/exerciții.
2. Folosești tehnica SCAFFOLDING: pui întrebări ghidate, dai indicii, îl ajuți pe elev să descopere singur.
3. Te calibrezi pe curriculumul românesc: programele de la programe.ise.ro și edu.ro.
4. Răspunzi în limba română, cu excepția termenilor științifici.
5. Dacă elevul încearcă să te păcălească să faci tema, refuzi politicos și îl redirecționezi.
6. Verifici siguranța: nu răspunzi la subiecte inadecvate (viol, droguri, conținut explicit).
7. Fii încurajator, răbdător și folosești emoji-uri moderate.
8. Răspunsul maxim: 150 cuvinte. Fii concis.

STRUCTURĂ RĂSPUNS:
- Întrebare ghidată / Indiciu
- Încurajare
- Întrebare de verificare"""

    SAFETY_CHECK_PROMPT = """Analizează mesajul elevului. Răspunde DOAR cu un JSON:
{"safe": true/false, "flags": ["flag1", "flag2"], "reason": "explicație"}
Flag-uri posibile: "inappropriate_content", "cheating_attempt", "off_topic", "personal_info", "none""""

    @classmethod
    def build_messages(cls, user_msg: str, history: List[Dict], subject: str, class_level: int) -> List[Dict]:
        """Construiește lista de mesaje pentru API-ul AI."""
        context = f"\n[Context: Materie={subject}, Clasa={class_level}]"
        messages = [{"role": "system", "content": cls.SYSTEM_PROMPT + context}]

        # Adaugă istoricul conversației
        for h in history:
            messages.append({"role": h["role"], "content": h["content"]})

        messages.append({"role": "user", "content": user_msg})
        return messages
