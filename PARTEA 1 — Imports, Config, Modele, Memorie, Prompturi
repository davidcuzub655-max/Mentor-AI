# MEMORIE CONVERSAȚII (In-Memory Cache)
# =============================================================================

class ConversationMemory:
    """
    Memorie pentru context conversațional.
    Păstrează ultimele 10 mesaje per conversație pentru continuitate.
    În producție: înlocuiește cu Redis.
    """
    def __init__(self, max_messages: int = 10):
        self._store: Dict[str, List[Dict]] = {}
        self.max_messages = max_messages

    def get(self, conversation_id: str) -> List[Dict]:
        return self._store.get(conversation_id, [])

    def add(self, conversation_id: str, role: str, content: str):
        if conversation_id not in self._store:
            self._store[conversation_id] = []
        self._store[conversation_id].append({
            "role": role,
            "content": content,
            "timestamp": time.time()
        })
        # Păstrează doar ultimele N mesaje
        if len(self._store[conversation_id]) > self.max_messages:
            self._store[conversation_id] = self._store[conversation_id][-self.max_messages:]

    def clear(self, conversation_id: str):
        self._store.pop(conversation_id, None)


