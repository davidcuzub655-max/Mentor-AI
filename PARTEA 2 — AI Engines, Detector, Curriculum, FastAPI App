@app.post("/api/chat", response_model=ChatResponse, tags=["AI Mentor"])
async def chat_endpoint(request: ChatRequest, req: Request):
    """
    ## 💬 AI Mentor Pedagogic

    Chat cu AI Mentor care folosește **Claude 3.5 Sonnet** (primar),
    **GPT-4o** (secundar), **Gemini 1.5 Pro** (failover).

    **Reguli:**
    - NU dă răspunsul direct — folosește scaffolding
    - Verifică siguranța mesajului înainte de procesare
    - Păstrează context conversațional per `conversation_id`

    **Exemplu request:**
    ```json
    {
      "message": "Cum rezolv ecuația 2x + 5 = 13?",
      "subject": "matematica",
      "class_level": 8
    }
    ```
    """
    client_ip = req.client.host
    if not rate_limiter.is_allowed(client_ip):
        raise HTTPException(status_code=429, detail="Prea multe cereri. Încearcă mai târziu.")

    return await ai_engines.chat(request)


