# =============================================================================

class AIDetector:
    """
    Detector AI profesional folosind GPTZero API.
    NU folosește Claude/GPT/Gemini — este un serviciu dedicat.
    """

    def __init__(self):
        self.client = httpx.AsyncClient(timeout=15.0)

    async def detect(self, request: DetectRequest) -> DetectResponse:
        """
        Analizează textul cu GPTZero API.

        GPTZero returnează:
        - completely_generated_prob: probabilitatea că textul e 100% AI
        - average_generated_prob: probabilitatea medie per propoziție
        - document_class: clasificare ("human", "mixed", "ai")
        """
        if not Config.GPTZERO_API_KEY:
            # Fallback: simulează un rezultat pentru demo (fără API key)
            return self._simulate_detection(request)

        start = time.time()
        try:
            response = await self.client.post(
                "https://api.gptzero.me/v2/predict",
                headers={
                    "X-Api-Key": Config.GPTZERO_API_KEY,
                    "Content-Type": "application/json"
                },
                json={
                    "document": request.text,
                    "version": "2024-01-01"
                }
            )
            response.raise_for_status()
            data = response.json()

            # Extrage rezultatele
            doc = data.get("documents", [{}])[0]
            ai_prob = doc.get("completely_generated_prob", 0) * 100
            avg_prob = doc.get("average_generated_prob", 0) * 100
            doc_class = doc.get("document_class", "unknown")

            # Mapare verdict
            verdict_map = {
                "human": ("✅ Text autentic (uman)", "authentic", "high"),
                "mixed": ("⚠️ Posibil amestec uman + AI", "mixed", "medium"),
                "ai": ("🔴 Text generat de AI", "ai", "high")
            }

            # Fallback pe scor dacă document_class lipsește
            if doc_class not in verdict_map:
                if ai_prob < 20:
                    doc_class = "human"
                elif ai_prob < 50:
                    doc_class = "mixed"
                else:
                    doc_class = "ai"

            verdict_text, verdict_code, confidence = verdict_map[doc_class]

            # Sugestii pentru părinte/profesor
            suggestions = self._generate_suggestions(ai_prob, doc_class)

            return DetectResponse(
                ai_probability=round(ai_prob, 1),
                verdict=verdict_text,
                verdict_code=verdict_code,
                confidence=confidence,
                details={
                    "completely_generated_prob": ai_prob,
                    "average_generated_prob": avg_prob,
                    "document_class": doc_class,
                    "raw_response": data
                },
                suggestions=suggestions,
                processing_time_ms=(time.time() - start) * 1000,
                engine="gptzero"
            )

        except httpx.HTTPStatusError as e:
            if e.response.status_code == 429:
                raise HTTPException(status_code=429, detail="Prea multe cereri la GPTZero. Încearcă în câteva secunde.")
            raise HTTPException(status_code=502, detail=f"Eroare GPTZero: {e.response.text}")
        except Exception as e:
            raise HTTPException(status_code=500, detail=f"Eroare detector: {str(e)}")

    def _generate_suggestions(self, ai_prob: float, doc_class: str) -> List[str]:
        """Generează recomandări pedagogice bazate pe scor."""
        if doc_class == "human":
            return [
                "✅ Textul arată autentic. Stilul natural și variațiile specifice elevului sunt evidente.",
                "💡 Continuă să încurajezi scrisul original și creativitatea.",
                "📚 Propune elevului să citească în continuare pentru a-și îmbogăți vocabularul."
            ]
        elif doc_class == "mixed":
            return [
                "⚠️ Textul conține elemente atât umane, cât și AI. Poate fi vorba de corectare gramaticală cu AI.",
                "🗣️ Recomandă o discuție orală cu elevul despre conținutul textului.",
                "📝 Cere elevului să rescrie textul cu cuvintele lui, fără ajutor digital."
            ]
        else:
            return [
                "🔴 Scor ridicat de AI detectat. Vocabularul academic și structura perfectă sugerează generare artificială.",
                "🎯 Intervenție pedagogică necesară: discută cu elevul despre procesul de scriere.",
                "📖 Propune exerciții de scriere creativă fără acces la AI pentru a dezvolta stilul propriu.",
                "👁️ Monitorizează activitatea elevului pe platformă pentru a identifica tipare."
            ]

    def _simulate_detection(self, request: DetectRequest) -> DetectResponse:
        """Simulează detectarea pentru demo (când nu există API key GPTZero)."""
        start = time.time()
        text = request.text.lower()

        # Heuristic simplu DOAR pentru demo
        indicators = {
            "complex_words": len([w for w in text.split() if len(w) > 12]),
            "perfect_punctuation": text.count(", ") > 5 and text.count(". ") > 3,
            "repetitive": len(set(text.split())) / len(text.split()) if text.split() else 1,
            "length": len(text)
        }

        score = 30
        if indicators["complex_words"] > 3: score += 15
        if indicators["perfect_punctuation"]: score += 10
        if indicators["repetitive"] > 0.7: score -= 10
        if indicators["length"] < 100: score -= 20

        score = max(5, min(95, score + (hash(text) % 20 - 10)))

        if score < 20:
            verdict, code, conf = "✅ Text autentic (uman) [DEMO]", "authentic", "medium"
        elif score < 50:
            verdict, code, conf = "⚠️ Posibil amestec [DEMO]", "mixed", "medium"
        else:
            verdict, code, conf = "🔴 Probabil generat de AI [DEMO]", "ai", "medium"

        return DetectResponse(
            ai_probability=round(score, 1),
            verdict=verdict,
            verdict_code=code,
            confidence=conf,
            details={"mode": "demo_simulation", "indicators": indicators},
            suggestions=self._generate_suggestions(score, code),
            processing_time_ms=(time.time() - start) * 1000,
            engine="gptzero_demo"
        )


