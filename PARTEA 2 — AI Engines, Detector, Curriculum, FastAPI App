@dataclass
class EngineResult:
    """Rezultat de la un AI engine"""
    success: bool
    content: str = ""
    engine: str = ""
    error: str = ""
    latency_ms: float = 0.0


class AIEngines:
    """
    Manager pentru cele 3 AI engines cu load balancing și failover.
    Ordinea: Claude (primar) → GPT-4o (secundar) → Gemini (failover).
    """

    def __init__(self):
        self.httpx_client = httpx.AsyncClient(timeout=Config.TIMEOUT_SECONDS)
        self.memory = ConversationMemory()
        self._request_count = 0
        self._start_time = time.time()

    # -------------------------------------------------------------------------
    # CLAUDE 3.5 SONNET (Primar)
    # -------------------------------------------------------------------------
    async def _call_claude(self, messages: List[Dict]) -> EngineResult:
        """Apelează Anthropic Claude 3.5 Sonnet via API."""
        if not Config.ANTHROPIC_API_KEY:
            return EngineResult(False, engine="claude", error="API key missing")

        start = time.time()
        try:
            # Extrage system prompt și conversație
            system_msg = messages[0]["content"] if messages[0]["role"] == "system" else ""
            conversation = [m for m in messages if m["role"] != "system"]

            response = await self.httpx_client.post(
                "https://api.anthropic.com/v1/messages",
                headers={
                    "x-api-key": Config.ANTHROPIC_API_KEY,
                    "anthropic-version": "2023-06-01",
                    "content-type": "application/json"
                },
                json={
                    "model": "claude-3-5-sonnet-20241022",
                    "max_tokens": 512,
                    "system": system_msg,
                    "messages": conversation,
                    "temperature": 0.7
                }
            )
            response.raise_for_status()
            data = response.json()
            content = data["content"][0]["text"]

            return EngineResult(
                success=True,
                content=content,
                engine="claude",
                latency_ms=(time.time() - start) * 1000
            )
        except httpx.TimeoutException:
            return EngineResult(False, engine="claude", error="Timeout", latency_ms=(time.time()-start)*1000)
        except Exception as e:
            return EngineResult(False, engine="claude", error=str(e), latency_ms=(time.time()-start)*1000)

    # -------------------------------------------------------------------------
    # GPT-4o (Secundar)
    # -------------------------------------------------------------------------
    async def _call_gpt4o(self, messages: List[Dict]) -> EngineResult:
        """Apelează OpenAI GPT-4o via API."""
        if not Config.OPENAI_API_KEY:
            return EngineResult(False, engine="gpt4o", error="API key missing")

        start = time.time()
        try:
            response = await self.httpx_client.post(
                "https://api.openai.com/v1/chat/completions",
                headers={
                    "Authorization": f"Bearer {Config.OPENAI_API_KEY}",
                    "Content-Type": "application/json"
                },
                json={
                    "model": "gpt-4o",
                    "messages": messages,
                    "max_tokens": 512,
                    "temperature": 0.7
                }
            )
            response.raise_for_status()
            data = response.json()
            content = data["choices"][0]["message"]["content"]

            return EngineResult(
                success=True,
                content=content,
                engine="gpt4o",
                latency_ms=(time.time() - start) * 1000
            )
        except httpx.TimeoutException:
            return EngineResult(False, engine="gpt4o", error="Timeout", latency_ms=(time.time()-start)*1000)
        except Exception as e:
            return EngineResult(False, engine="gpt4o", error=str(e), latency_ms=(time.time()-start)*1000)

    # -------------------------------------------------------------------------
    # GEMINI 1.5 PRO (Failover)
    # -------------------------------------------------------------------------
    async def _call_gemini(self, messages: List[Dict]) -> EngineResult:
        """Apelează Google Gemini 1.5 Pro via API."""
        if not Config.GOOGLE_API_KEY:
            return EngineResult(False, engine="gemini", error="API key missing")

        start = time.time()
        try:
            # Converteste formatul OpenAI în format Gemini
            contents = []
            for m in messages:
                role = "model" if m["role"] == "system" else ("user" if m["role"] == "user" else "model")
                contents.append({"role": role, "parts": [{"text": m["content"]}]})

            response = await self.httpx_client.post(
                f"https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-pro:generateContent?key={Config.GOOGLE_API_KEY}",
                headers={"Content-Type": "application/json"},
                json={
                    "contents": contents,
                    "generationConfig": {"temperature": 0.7, "maxOutputTokens": 512}
                }
            )
            response.raise_for_status()
            data = response.json()
            content = data["candidates"][0]["content"]["parts"][0]["text"]

            return EngineResult(
                success=True,
                content=content,
                engine="gemini",
                latency_ms=(time.time() - start) * 1000
            )
        except httpx.TimeoutException:
            return EngineResult(False, engine="gemini", error="Timeout", latency_ms=(time.time()-start)*1000)
        except Exception as e:
            return EngineResult(False, engine="gemini", error=str(e), latency_ms=(time.time()-start)*1000)

    # -------------------------------------------------------------------------
    # SAFETY CHECK (pre-chat)
    # -------------------------------------------------------------------------
    async def _safety_check(self, message: str) -> Dict[str, Any]:
        """Verifică dacă mesajul este sigur înainte de a trimite la AI."""
        inappropriate_keywords = [
            "bomba", "arma", "ucide", "sinucidere", "droguri", "sex explicit",
            "pornografie", "hack", "fura banca", "virus"
        ]
        flags = []
        msg_lower = message.lower()

        for kw in inappropriate_keywords:
            if kw in msg_lower:
                flags.append("inappropriate_content")

        # Verifică tentativă de "fă tema mea"
        cheating_patterns = [
            "rezolvă-mi", "fă-mi tema", "scrie-mi compunerea", "dă-mi răspunsul",
            "copiază", "plagiază", "fă tot exercițiul"
        ]
        for pattern in cheating_patterns:
            if pattern in msg_lower:
                flags.append("cheating_attempt")

        return {
            "safe": len(flags) == 0,
            "flags": flags if flags else ["none"]
        }

    # -------------------------------------------------------------------------
    # ORCHESTRATOR (Failover Chain)
    # -------------------------------------------------------------------------
    async def chat(self, request: ChatRequest) -> ChatResponse:
        """
        Orchestrator principal:
        1. Safety check
        2. Încarcă memoria conversației
        3. Încearcă Claude → GPT-4o → Gemini
        4. Salvează în memorie
        5. Returnează răspuns + metadate
        """
        start_total = time.time()
        conv_id = request.conversation_id or f"conv_{hashlib.md5(request.message.encode()).hexdigest()[:8]}"

        # 1. Safety check
        safety = await self._safety_check(request.message)
        if not safety["safe"]:
            return ChatResponse(
                response="🛡️ Hei! Am detectat că întrebarea ta nu este adecvată pentru platforma noastră educațională. Încearcă să reformulezi folosind cuvinte potrivite școlii! 📚",
                engine_used="safety_filter",
                subject=request.subject.value,
                class_level=request.class_level,
                scaffolding_level=0,
                safety_flags=safety["flags"],
                processing_time_ms=(time.time() - start_total) * 1000,
                conversation_id=conv_id
            )

        # 2. Încarcă istoric
        history = self.memory.get(conv_id)
        messages = PedagogicPrompts.build_messages(
            request.message, history, request.subject.value, request.class_level
        )

        # 3. Failover chain: Claude → GPT-4o → Gemini
        engines = [
            ("claude", self._call_claude),
            ("gpt4o", self._call_gpt4o),
            ("gemini", self._call_gemini)
        ]

        result: Optional[EngineResult] = None
        used_engine = ""

        for engine_name, engine_func in engines:
            result = await engine_func(messages)
            if result.success:
                used_engine = engine_name
                break
            # Dacă e timeout, trecem imediat la următorul
            if "Timeout" in result.error:
                continue

        # 4. Dacă toate au eșuat
        if not result or not result.success:
            return ChatResponse(
                response="⚠️ Momentan toate serverele AI sunt ocupate. Te rog să încerci din nou în câteva secunde. Între timp, încearcă să rezolvi singur folosind manualul! 💪",
                engine_used="all_failed",
                subject=request.subject.value,
                class_level=request.class_level,
                scaffolding_level=0,
                safety_flags=["engine_failure"],
                processing_time_ms=(time.time() - start_total) * 1000,
                conversation_id=conv_id
            )

        # 5. Salvează în memorie
        self.memory.add(conv_id, "user", request.message)
        self.memory.add(conv_id, "assistant", result.content)
        self._request_count += 1

        # 6. Calculează nivel scaffolding (1-3) bazat pe lungimea istoricului
        scaffolding = min(3, 1 + len(history) // 3)

        return ChatResponse(
            response=result.content,
            engine_used=used_engine,
            subject=request.subject.value,
            class_level=request.class_level,
            scaffolding_level=scaffolding,
            safety_flags=safety["flags"],
            processing_time_ms=(time.time() - start_total) * 1000,
            conversation_id=conv_id
        )

    async def health(self) -> Dict[str, Any]:
        """Verifică statusul tuturor AI engines."""
        engines_status = {}

        # Test rapid fiecare engine cu un ping simplu
        for name, func in [("claude", self._call_claude), ("gpt4o", self._call_gpt4o), ("gemini", self._call_gemini)]:
            start = time.time()
            try:
                # Test ping cu mesaj minim
                test_msg = [{"role": "user", "content": "Say 'ok' only."}]
                result = await func(test_msg)
                engines_status[name] = {
                    "status": "online" if result.success else "error",
                    "latency_ms": round(result.latency_ms, 1),
                    "error": result.error if not result.success else None
                }
            except Exception as e:
                engines_status[name] = {"status": "offline", "error": str(e)}

        return {
            "status": "healthy" if any(e["status"] == "online" for e in engines_status.values()) else "degraded",
            "version": Config.APP_VERSION,
            "engines": engines_status,
            "uptime_seconds": round(time.time() - self._start_time, 1),
            "requests_total": self._request_count
        }


