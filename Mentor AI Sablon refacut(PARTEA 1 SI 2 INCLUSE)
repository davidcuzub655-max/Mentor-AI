const TimerScreen = ({ onFinish, onToast }) => {
  const [seconds, setSeconds] = useState(25 * 60);
  const [isRunning, setIsRunning] = useState(false);
  const [sound, setSound] = useState('mute');
  const intervalRef = useRef(null);
  useEffect(() => { if (isRunning) { intervalRef.current = setInterval(() => { setSeconds(s => { if (s <= 1) { clearInterval(intervalRef.current); setIsRunning(false); onFinish(); return 0; } return s - 1; }); }, 1000); } return () => clearInterval(intervalRef.current); }, [isRunning, onFinish]);
  const toggleTimer = () => setIsRunning(!isRunning);
  const stopTimer = () => { clearInterval(intervalRef.current); setIsRunning(false); onFinish(); };
  const circumference = 754;
  const totalSeconds = 25 * 60;
  const offset = circumference - ((totalSeconds - seconds) / totalSeconds) * circumference;
  const sounds = [{ id: 'mute', icon: 'fa-volume-mute', label: 'Fără sunet' },{ id: 'rain', icon: 'fa-cloud-rain', label: 'Ploaie' },{ id: 'forest', icon: 'fa-tree', label: 'Pădure' },{ id: 'lofi', icon: 'fa-music', label: 'Lo-Fi' }];
  return (
    <div className="min-h-screen flex flex-col items-center justify-center px-5 pb-24 animate-fadeIn">
      <div className="text-lg font-bold mb-2">Biologie</div>
      <div className="text-sm text-slate-400 mb-8">ADN și replicare</div>
      <div className="relative w-[260px] h-[260px] mb-10">
        <svg width="260" height="260" viewBox="0 0 260 260" className="-rotate-90">
          <circle cx="130" cy="130" r="120" fill="none" stroke="rgba(255,255,255,0.08)" strokeWidth="12" />
          <circle cx="130" cy="130" r="120" fill="none" stroke="url(#timerGradient)" strokeWidth="12" strokeLinecap="round" strokeDasharray={circumference} strokeDashoffset={offset} className="transition-all duration-1000 linear" />
        </svg>
        <div className="absolute inset-0 flex flex-col items-center justify-center">
          <div className="text-[56px] font-black tracking-tighter tabular-nums">{formatTime(seconds)}</div>
          <div className="text-sm text-slate-400 mt-1">Focus Time</div>
        </div>
      </div>
      <div className="flex gap-5 mb-8">
        <button onClick={stopTimer} className="w-16 h-16 rounded-full bg-red-500 flex items-center justify-center text-white text-2xl shadow-[0_8px_30px_rgba(239,68,68,0.4)] hover:scale-110 transition"><i className="fas fa-stop"></i></button>
        <button onClick={toggleTimer} className={"w-16 h-16 rounded-full flex items-center justify-center text-white text-2xl shadow-[0_8px_30px_rgba(124,58,237,0.4)] hover:scale-110 transition " + (isRunning ? 'bg-amber-500 shadow-[0_8px_30px_rgba(245,158,11,0.4)]' : 'gradient-primary')}><i className={"fas " + (isRunning ? 'fa-pause' : 'fa-play')}></i></button>
      </div>
      <div className="flex gap-2.5 flex-wrap justify-center">
        {sounds.map(s => (
          <button key={s.id} onClick={() => setSound(s.id)} className={"px-4 py-2 rounded-full text-xs font-semibold transition border " + (sound === s.id ? 'bg-[#7c3aed] text-white border-[#7c3aed]' : 'bg-[#1a1a3e] text-slate-400 border-white/10 hover:bg-[#7c3aed]/20')}><i className={"fas " + s.icon + " mr-1.5"}></i>{s.label}</button>
        ))}
      </div>
    </div>
  );
};

