      "résous pour moi","fais mes devoirs","löse für mich","mach meine hausaufgaben",
      "resuelve para mí","haz mi tarea","risolvi per me","fai i miei compiti",
      "реши за меня","сделай мою домашку","old meg helyettem","írd meg helyettem",
      "benim için çöz","ödevimi yap","帮我做","给我答案","私のために解いて","宿題をやって"
    ];
    const flags = [];
    for (const kw of inappropriate) if (msgLower.includes(kw)) flags.push("inappropriate_content");
    for (const pattern of cheating) if (msgLower.includes(pattern.toLowerCase())) flags.push("cheating_attempt");
    const directPatterns = [/^(care este|ce este|cum se|defin|explic|spune-mi|tell me|what is|how to|define|explain|dă-mi|give me|donne-moi|gib mir|dame|dammi|дай мне|add meg|ver bana|给我|教えて)/i];
    let isDirect = false;
    for (const p of directPatterns) if (p.test(message.trim())) { isDirect = true; break; }
    return { safe: flags.length === 0, flags: flags.length ? flags : ["none"], isDirectRequest: isDirect };
  },

