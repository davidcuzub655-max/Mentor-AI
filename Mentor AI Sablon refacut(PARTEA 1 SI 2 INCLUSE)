  async safetyCheck(message) {
    const msgLower = message.toLowerCase();
    const inappropriate = ["bomba","arma","ucide","sinucidere","droguri","sex explicit","pornografie","hack","fura banca","virus","terorism","criminal","viol","abuz"];
    const cheating = [
      "rezolvă-mi","fă-mi tema","scrie-mi compunerea","dă-mi răspunsul","copiază","plagiază","fă tot exercițiul","fă-mi tot","răspunde la tot",
